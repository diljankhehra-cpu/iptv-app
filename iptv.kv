<FloatLayout>:
    Video:
        id: player
        size_hint: 1, 0.7
        pos_hint: {"x":0, "y":0.2}
    Label:
        id: ch_name
        text: "Channel Name"
        size_hint: 1, 0.05
        pos_hint: {"x":0, "y":0.95}
        halign: "center"
    Label:
        id: program
        text: "Now Playing..."
        size_hint: 1, 0.05
        pos_hint: {"x":0, "y":0.9}
        halign: "center"
    Image:
        id: wm
        size_hint: None, None
        size: 120, 60
        pos: 10, 10
    BoxLayout:
        id: topbar
        size_hint: 1, 0.05
        pos_hint: {"x":0, "y":0.85}
        opacity: 0
    BoxLayout:
        id: menu
        size_hint: 1, 0.05
        pos_hint: {"x":0, "y":0.8}
        opacity: 0
    BoxLayout:
        id: epg
        size_hint: 1, 0.05
        pos_hint: {"x":0, "y":0.75}
        opacity: 0
