name: Build APK

on:
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
    # 1️⃣ Checkout repo
    - name: Checkout Repository
      uses: actions/checkout@v3

    # 2️⃣ Setup Python
    - name: Setup Python
      uses: actions/setup-python@v4
      with:
        python-version: "3.11"

    # 3️⃣ Create Buildozer venv + install packages
    - name: Setup Buildozer venv
      shell: bash
      run: |
        python -m venv buildozer-venv
        source buildozer-venv/bin/activate
        pip install --upgrade pip setuptools wheel
        pip install cython==0.29.36 buildozer python-for-android

    # 4️⃣ Install Android cmdline-tools + accept licenses + Build-tools 33.x
    - name: Install Build-Tools + AIDL
      shell: bash
      run: |
        SDK_ROOT=$HOME/.buildozer/android/platform/android-sdk
        mkdir -p $SDK_ROOT/cmdline-tools

        # Download cmdline-tools only if missing
        if [ ! -f "$SDK_ROOT/cmdline-tools/latest/bin/sdkmanager" ]; then
          wget -q https://dl.google.com/android/repository/commandlinetools-linux-9477386_latest.zip -O cmdline-tools.zip
          unzip -q cmdline-tools.zip -d $SDK_ROOT/cmdline-tools/
          rm cmdline-tools.zip
          mv $SDK_ROOT/cmdline-tools/cmdline-tools $SDK_ROOT/cmdline-tools/latest
        fi

        export ANDROID_SDK_ROOT=$SDK_ROOT

        # Accept all licenses non-interactively
        yes | $SDK_ROOT/cmdline-tools/latest/bin/sdkmanager --sdk_root=$SDK_ROOT --licenses

        # Install build-tools (includes AIDL) + platform
        $SDK_ROOT/cmdline-tools/latest/bin/sdkmanager --sdk_root=$SDK_ROOT \
          "build-tools;33.0.2" "platforms;android-33"

        # Verify aidl
        $SDK_ROOT/build-tools/33.0.2/aidl --help || echo "AIDL check complete"

    # 5️⃣ Build APK
    - name: Build APK
      shell: bash
      working-directory: ./   # jithe buildozer.spec hai
      run: |
        source buildozer-venv/bin/activate
        python -m buildozer android debug
